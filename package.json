{
  "name": "wtenv",
  "version": "0.1.0",
  "description": "Worktree environment manager — per-worktree DNS namespaces, port allocation, and database isolation for Conductor-managed git worktrees",
  "type": "module",
  "bin": {
    "wtenv": "./dist/index.js"
  },
  "exports": {
    ".": "./dist/lib/exports.js"
  },
  "main": "./dist/lib/exports.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "link": "npm run build && npm link"
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
