{
  "name": "wtenv",
  "version": "0.1.0",
  "description": "Worktree environment manager — per-worktree DNS namespaces, port allocation, and database isolation for Conductor-managed git worktrees",
  "type": "module",
  "bin": {
    "wtenv": "./dist/index.js"
  },
  "exports": {
    ".": "./dist/lib/exports.js"
  },
  "main": "./dist/lib/exports.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "link": "npm run build && npm link"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "commander": "^15.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
